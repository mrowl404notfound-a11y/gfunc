class C:
    RST = "\033[0m"
    B   = "\033[1m"
    DIM = "\033[2m"
    RED = "\033[91m"
    GRN = "\033[92m"
    YEL = "\033[93m"
    BLU = "\033[94m"
    MAG = "\033[95m"
    CYN = "\033[96m"
    GRY = "\033[90m"

    @classmethod
    def off(cls):
        for a in ['RST','B','DIM','RED','GRN','YEL','BLU','MAG','CYN','GRY']:
            setattr(cls, a, "")

